# SubMeter — Environment Variables
# Copy to .env and fill in real values.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev: matches the docker-compose.yml postgres service defaults.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/submeter
SPRING_DATASOURCE_USERNAME=submeter
SPRING_DATASOURCE_PASSWORD=submeter_dev

# ── JWT ───────────────────────────────────────────────────────────────────────
# Minimum 32 characters. Use: openssl rand -hex 32
JWT_SECRET=change-this-to-a-64-char-random-secret-use-openssl-rand-hex-32

# ── Razorpay (TEST MODE ONLY) ─────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Use rzp_test_* keys only — the app will refuse to start with rzp_live_* keys.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Set in Razorpay dashboard → Settings → Webhooks → Webhook Secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret-here

# ── Dev Mode ──────────────────────────────────────────────────────────────────
# true  → enables /api/dev/* endpoints (mock webhook, email log viewer)
# false → these endpoints return 404 regardless of auth
DEV_MODE=true

# ── Storage ───────────────────────────────────────────────────────────────────
# Local path for generated invoice PDFs.
# Production: set to a mounted volume path (see docker-compose.prod.yml).
STORAGE_PATH=./storage

# ── Frontend ──────────────────────────────────────────────────────────────────
# Prefixed with NEXT_PUBLIC_ so Next.js exposes it to the browser bundle.
NEXT_PUBLIC_API_URL=http://localhost:8080/api
